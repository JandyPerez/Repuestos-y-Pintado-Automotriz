<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="690.0" prefWidth="920.0" style="-fx-background-color: #F0F5FB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.puestosypintado.controladores.VentaController">
    <children>

        <!-- HEADER -->
        <Pane prefHeight="48.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0"
                       style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;"
                       text="VENTAS DE MOSTRADOR" />
                <Label layoutX="480.0" layoutY="17.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"
                       text="FERRETERIA — PROCESAMIENTO DE VENTAS" />
            </children>
        </Pane>

        <!-- HOME -->
        <Button onAction="#irHome" text="HOME" prefHeight="26.0" prefWidth="80.0"
                style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.50); -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3;"
                AnchorPane.topAnchor="11.0" AnchorPane.rightAnchor="12.0">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <!-- SPLIT PANE -->
        <SplitPane dividerPositions="0.42" layoutY="48.0" prefHeight="636.0" prefWidth="920.0"
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;"
                   AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- LEFT — tabla de ventas -->
                <AnchorPane minHeight="0.0" minWidth="0.0"
                            style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="VENTAS DEL DIA" />
                        <TableView fx:id="tvVentas" layoutY="32.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;"
                                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colIdVenta"      prefWidth="50.0"  text="ID" />
                                <TableColumn fx:id="colClienteVenta" prefWidth="140.0" text="CLIENTE" />
                                <TableColumn fx:id="colTotalVenta"   prefWidth="90.0"  text="TOTAL" />
                                <TableColumn fx:id="colEstadoVenta"  prefWidth="90.0"  text="ESTADO" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- RIGHT — FORM -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ID VENTA -->
                        <Label layoutX="20.0" layoutY="18.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="ID VENTA" />
                        <TextField fx:id="txtIdVenta" layoutX="110.0" layoutY="12.0"
                                   prefHeight="28.0" prefWidth="80.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px;" />
                        <Button layoutX="198.0" layoutY="12.0" onAction="#fnBuscarVenta"
                                prefHeight="28.0" prefWidth="34.0"
                                style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;"
                                text="🔍">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <Line endX="450.0" endY="0.0" layoutY="50.0" startX="20.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- CLIENTE + VEHICULO -->
                        <Label layoutX="20.0" layoutY="63.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="CLIENTE *" />
                        <ComboBox fx:id="cmbClienteVenta" layoutX="110.0" layoutY="59.0"
                                  prefHeight="28.0" prefWidth="315.0" promptText="Seleccione cliente..."
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />

                        <Label layoutX="20.0" layoutY="101.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="VEHICULO" />
                        <ComboBox fx:id="cmbVehiculoVenta" layoutX="110.0" layoutY="97.0"
                                  prefHeight="28.0" prefWidth="315.0" promptText="Opcional..."
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />

                        <!-- SECCION DETALLE ITEMS -->
                        <Label layoutX="20.0" layoutY="141.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="ITEMS DE LA VENTA" />
                        <Line endX="450.0" endY="0.0" layoutY="158.0" startX="20.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- buscador de repuesto + cantidad + agregar -->
                        <Label layoutX="20.0" layoutY="168.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="REPUESTO" />
                        <ComboBox fx:id="cmbRepuestoVenta" layoutX="110.0" layoutY="164.0"
                                  prefHeight="28.0" prefWidth="200.0" promptText="Buscar repuesto..."
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />

                        <Label layoutX="320.0" layoutY="168.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="CANT." />
                        <TextField fx:id="txtCantVenta" layoutX="355.0" layoutY="164.0"
                                   prefHeight="28.0" prefWidth="50.0" text="1"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 12px;" />
                        <Button layoutX="413.0" layoutY="164.0" onAction="#fnAgregarItem"
                                prefHeight="28.0" prefWidth="55.0"
                                style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 2;"
                                text="AÑADIR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <!-- tabla de items -->
                        <TableView fx:id="tvItemsVenta" layoutY="198.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-faint-focus-color: transparent;"
                                   AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                                   AnchorPane.topAnchor="198.0" AnchorPane.bottomAnchor="256.0">
                            <columns>
                                <TableColumn fx:id="colItemRepuesto"  prefWidth="200.0" text="REPUESTO" />
                                <TableColumn fx:id="colItemCantidad"  prefWidth="70.0"  text="CANT." />
                                <TableColumn fx:id="colItemPrecio"    prefWidth="100.0" text="PRECIO UNIT." />
                                <TableColumn fx:id="colItemSubtotal"  prefWidth="100.0" text="SUBTOTAL" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- TOTALES -->
                        <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555555;"
                               text="SUBTOTAL:"
                               AnchorPane.bottomAnchor="220.0" AnchorPane.rightAnchor="170.0" />
                        <TextField fx:id="txtSubtotalVenta" disable="true" prefHeight="26.0" prefWidth="120.0"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 1 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;"
                                   AnchorPane.bottomAnchor="214.0" AnchorPane.rightAnchor="20.0" />

                        <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555555;"
                               text="IMPUESTOS:"
                               AnchorPane.bottomAnchor="182.0" AnchorPane.rightAnchor="170.0" />
                        <TextField fx:id="txtImpuestosVenta" disable="true" prefHeight="26.0" prefWidth="120.0"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 1 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px;"
                                   AnchorPane.bottomAnchor="176.0" AnchorPane.rightAnchor="20.0" />

                        <Label style="-fx-font-family: Courier New; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="TOTAL:"
                               AnchorPane.bottomAnchor="142.0" AnchorPane.rightAnchor="170.0" />
                        <TextField fx:id="txtTotalVenta" disable="true" prefHeight="30.0" prefWidth="120.0"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 14px; -fx-font-weight: bold;"
                                   AnchorPane.bottomAnchor="134.0" AnchorPane.rightAnchor="20.0" />

                        <!-- METODO DE PAGO -->
                        <Label layoutX="20.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="METODO DE PAGO"
                               AnchorPane.bottomAnchor="102.0" AnchorPane.leftAnchor="20.0" />
                        <ComboBox fx:id="cmbMetodoPagoVenta" prefHeight="28.0" prefWidth="200.0"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;"
                                  AnchorPane.bottomAnchor="66.0" AnchorPane.leftAnchor="20.0" />

                        <Line endX="450.0" endY="0.0" startX="20.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;"
                              AnchorPane.bottomAnchor="56.0" AnchorPane.leftAnchor="20.0" />

                        <!-- BOTONES -->
                        <HBox alignment="CENTER" prefHeight="42.0" spacing="10.0"
                              AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnConfirmarVenta"
                                        prefHeight="34.0" prefWidth="140.0"
                                        style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="CONFIRMAR VENTA">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnQuitarItem"
                                        prefHeight="34.0" prefWidth="110.0"
                                        style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #E63939; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="QUITAR ITEM">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiarVenta"
                                        prefHeight="34.0" prefWidth="90.0"
                                        style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </AnchorPane>
            </items>
        </SplitPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
    </children>
</AnchorPane>
