<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420.0" prefWidth="420.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.LoginController">

    <children>

        <!-- FRANJA SUPERIOR -->
        <Pane prefHeight="68.0" prefWidth="420.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutY="8.0" prefWidth="420.0" style="-fx-font-family: Impact; -fx-font-size: 26px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-alignment: CENTER;" text="INICIAR SESION" />
                <Label layoutY="44.0" prefWidth="420.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.85); -fx-alignment: CENTER;" text="Repuestos y Pintado — Acceso al sistema" />
            </children>
        </Pane>

        <!-- TARJETA CENTRAL -->
        <VBox layoutX="60.0" layoutY="115.0" prefWidth="300.0" spacing="0.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;">
            <children>

                <!-- Cuerpo del formulario -->
                <VBox spacing="18.0" style="-fx-padding: 24 24 20 24;">
                    <children>

                        <!-- Usuario -->
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="USUARIO" />
                                <TextField fx:id="txtUsuario" onAction="#fnLogin" promptText="Ingrese su usuario" style="-fx-background-color: #F8FCFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-border-radius: 2; -fx-background-radius: 2; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-padding: 6 10 6 10;" />
                            </children>
                        </VBox>

                        <!-- Contraseña -->
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="CONTRASENA" />
                                <PasswordField fx:id="txtPassword" onAction="#fnLogin" promptText="Ingrese su contrasena" style="-fx-background-color: #F8FCFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-border-radius: 2; -fx-background-radius: 2; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-padding: 6 10 6 10;" />
                            </children>
                        </VBox>

                        <!-- Mensaje de error (oculto por defecto) -->
                        <Label fx:id="lblError" prefWidth="252.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-text-fill: #CC0000; -fx-font-weight: bold; -fx-alignment: CENTER;" text="" visible="false" />

                        <!-- Botón ENTRAR -->
                        <Button maxWidth="Infinity" onAction="#fnLogin" prefHeight="36.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 3; -fx-border-radius: 3;" text="ENTRAR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                    </children>
                </VBox>

            </children>
        </VBox>

        <!-- FRANJA INFERIOR -->
        <Pane prefHeight="6.0" prefWidth="420.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

        <!-- Versión -->
        <Label layoutX="0.0" layoutY="394.0" prefWidth="420.0" style="-fx-font-family: Courier New; -fx-font-size: 9px; -fx-text-fill: #AAAAAA; -fx-alignment: CENTER;" />

    </children>
</AnchorPane>
