<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!--
    PANTALLA 8 — ENTREGA DEL VEHÍCULO
    UPDATE → tbl.Servicio_Pintura via sp_EntregarVehiculo
             estado: 'terminado' → 'entregado'
    Prerequisitos (verificados en el controlador antes de habilitar el botón):
      · fn_SaldoPendienteServicio = 0
      · No hay incidencias abiertas (vw_IncidenciasAbiertas vacía para este servicio)
    READ   → tbl.Servicio_Pintura, tbl.Cliente, tbl.Vehiculo (resumen completo)
    READ   → tbl.Detalle_Servicio_Pintura + tbl.Subservicios (lista de trabajos)
    INSERT → tbl.Log_Auditoria (automático dentro del SP)
-->

<AnchorPane prefHeight="580.0" prefWidth="700.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.EntregaVehiculoController">
    <children>

        <!-- HEADER -->
        <Pane prefHeight="48.0" prefWidth="700.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #00AA77, #0066CC);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="ENTREGA DE VEHÍCULO" />
                <Label layoutX="400.0" layoutY="17.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="TALLER — CONFIRMACIÓN DE ENTREGA" />
            </children>
        </Pane>

        <!-- Botón HOME (flotante sobre el header) -->
        <Button onAction="#irHome" prefHeight="26.0" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.50); -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3;" text="HOME" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="11.0">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <!-- BANDA DE VERIFICACIÓN — verde si listo, rojo si hay bloqueos -->
        <Pane fx:id="paneVerificacion" layoutY="48.0" prefHeight="36.0" prefWidth="700.0" style="-fx-background-color: #00AA77;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <!-- Se actualiza dinámicamente según condiciones -->
                <Label fx:id="lblVerificacion" layoutX="20.0" layoutY="9.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="✓  LISTO PARA ENTREGA — Sin saldo pendiente ni incidencias abiertas" />
            </children>
        </Pane>

        <!-- RESUMEN DEL SERVICIO -->
        <AnchorPane layoutY="84.0" style="-fx-background-color: #F8FCFF;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="84.0">
            <children>

                <!-- DATOS CLIENTE / VEHÍCULO -->
                <Label layoutX="20.0" layoutY="14.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="RESUMEN DE LA ORDEN" />
                <Line endX="660.0" endY="0.0" layoutX="20.0" layoutY="30.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.4;" />

                <Label layoutX="20.0" layoutY="40.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="ORDEN #" />
                <TextField fx:id="txtIdOrden" disable="true" layoutX="90.0" layoutY="36.0" prefHeight="26.0" prefWidth="70.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;" />

                <Label layoutX="178.0" layoutY="40.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="CLIENTE" />
                <TextField fx:id="txtCliente" disable="true" layoutX="230.0" layoutY="36.0" prefHeight="26.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Label layoutX="20.0" layoutY="74.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="TELÉFONO" />
                <TextField fx:id="txtTelefono" disable="true" layoutX="90.0" layoutY="70.0" prefHeight="26.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Label layoutX="255.0" layoutY="74.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="PLACA" />
                <TextField fx:id="txtPlaca" disable="true" layoutX="300.0" layoutY="70.0" prefHeight="26.0" prefWidth="110.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Label layoutX="426.0" layoutY="74.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="VEHÍCULO" />
                <TextField fx:id="txtVehiculo" disable="true" layoutX="490.0" layoutY="70.0" prefHeight="26.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Line endX="660.0" endY="0.0" layoutX="20.0" layoutY="106.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.4;" />

                <!-- SUBSERVICIOS REALIZADOS -->
                <Label layoutX="20.0" layoutY="114.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="TRABAJOS REALIZADOS" />

                <!-- tbl.Detalle_Servicio_Pintura JOIN tbl.Subservicios WHERE estado = 'completado' -->
                <TableView fx:id="tvSubserviciosRealizados" layoutY="132.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="218.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="132.0">
                    <columns>
                        <TableColumn fx:id="colSubNombre" prefWidth="220.0" text="SUBSERVICIO" />
                        <TableColumn fx:id="colSubTecnico" prefWidth="180.0" text="TÉCNICO PINTURA" />
                        <TableColumn fx:id="colSubFecFin" prefWidth="140.0" text="COMPLETADO" />
                        <TableColumn fx:id="colSubEstado" prefWidth="100.0" text="ESTADO" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Line endX="660.0" endY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.4;" AnchorPane.bottomAnchor="214.0" AnchorPane.leftAnchor="20.0" />

                <!-- RESUMEN FINANCIERO -->
                <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="RESUMEN FINANCIERO" AnchorPane.bottomAnchor="190.0" AnchorPane.leftAnchor="20.0" />

                <HBox spacing="40.0" AnchorPane.bottomAnchor="144.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
                    <children>
                        <AnchorPane prefWidth="200.0">
                            <children>
                                <Label layoutX="0.0" layoutY="0.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="COSTO TOTAL" />
                                <!-- fn_CalcularCostoTotalServicio -->
                                <TextField fx:id="txtCostoTotal" disable="true" layoutX="110.0" layoutY="-4.0" prefHeight="26.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;" />
                            </children>
                        </AnchorPane>
                        <AnchorPane prefWidth="200.0">
                            <children>
                                <Label layoutX="0.0" layoutY="0.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="TOTAL PAGADO" />
                                <TextField fx:id="txtTotalPagado" disable="true" layoutX="110.0" layoutY="-4.0" prefHeight="26.0" prefWidth="90.0" style="-fx-background-color: #ffffff; -fx-border-color: transparent transparent #c5ced6 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #ffffff; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;" />
                            </children>
                        </AnchorPane>
                        <AnchorPane prefWidth="200.0">
                            <children>
                                <Label layoutX="0.0" layoutY="0.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #555555;" text="SALDO PENDIENTE" />
                                <!-- fn_SaldoPendienteServicio — debe ser 0 -->
                                <TextField fx:id="txtSaldoPendiente" disable="true" layoutX="120.0" layoutY="-4.0" prefHeight="26.0" prefWidth="80.0" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #FF6B6B transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #ffffff; -fx-font-family: Courier New; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>

                <Line endX="660.0" endY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.4;" AnchorPane.bottomAnchor="136.0" AnchorPane.leftAnchor="20.0" />

                <!-- EMPLEADO QUE ENTREGA — sesión activa -->
                <Label style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ENTREGADO POR" AnchorPane.bottomAnchor="102.0" AnchorPane.leftAnchor="20.0" />
                <TextField fx:id="txtEmpleadoEntrega" disable="true" prefHeight="28.0" prefWidth="280.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" AnchorPane.bottomAnchor="96.0" AnchorPane.leftAnchor="160.0" />
                <!-- fk_usuario — oculto -->
                <TextField fx:id="txtIdUsuario" editable="false" layoutX="483.0" layoutY="366.0" prefHeight="28.0" prefWidth="60.0" style="-fx-background-color: #F0F5FB; -fx-text-fill: transparent;" AnchorPane.bottomAnchor="96.0" AnchorPane.leftAnchor="483.0" />

                <Line endX="660.0" endY="0.0" style="-fx-stroke: #00AA77; -fx-opacity: 0.4;" AnchorPane.bottomAnchor="86.0" AnchorPane.leftAnchor="20.0" />

                <!-- BOTONES -->
                <HBox alignment="CENTER" spacing="14.0" AnchorPane.bottomAnchor="36.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
                    <children>
                        <!-- sp_EntregarVehiculo — deshabilitado si saldo > 0 o incidencias abiertas -->
                        <Button fx:id="btnConfirmarEntrega" mnemonicParsing="false" onAction="#fnConfirmarEntrega" prefHeight="36.0" prefWidth="200.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="CONFIRMAR ENTREGA">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#fnCancelar" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #888888; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 2;" text="CANCELAR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </HBox>

            </children>
        </AnchorPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" prefWidth="700.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #00AA77, #0066CC);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
