<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<!--
    PANTALLA 7 — RESOLVER INCIDENCIA
    UPDATE → tbl.Incidencias_Servicio via sp_ResolverIncidencia
             estado: 'abierta'/'en_correccion' → 'resuelta'
    Efecto → si no quedan incidencias abiertas, servicio vuelve a 'terminado'
    READ   → tbl.Incidencias_Servicio (datos de la incidencia a resolver)
    READ   → tbl.Empleado (fk_supervisor = sesión activa)
-->
<AnchorPane prefHeight="480.0" prefWidth="640.0" style="-fx-background-color: #F0F5FB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.puestosypintado.controladores.ResolverIncidenciaController">
    <children>

        <!-- HEADER -->
        <Pane prefHeight="48.0" prefWidth="640.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #CC6600, #FFAA33);"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0"
                       style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;"
                       text="RESOLVER INCIDENCIA" />
                <Label layoutX="360.0" layoutY="17.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"
                       text="TALLER — CIERRE DE DEFECTO" />
            </children>
        </Pane>

        <!-- DATOS DE LA INCIDENCIA (solo lectura) -->
        <Pane layoutY="48.0" prefHeight="44.0" prefWidth="640.0"
              style="-fx-background-color: #E8F1F8; -fx-border-color: #CC6600; -fx-border-width: 0 0 2 0;"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label layoutX="15.0" layoutY="8.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #CC6600;"
                       text="INCIDENCIA #" />
                <TextField fx:id="txtIdIncidencia" disable="true" layoutX="100.0" layoutY="4.0"
                           prefHeight="26.0" prefWidth="60.0"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #CC6600; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;" />

                <Label layoutX="175.0" layoutY="8.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #555555;"
                       text="ORDEN #" />
                <TextField fx:id="txtIdOrdenCtx" disable="true" layoutX="225.0" layoutY="4.0"
                           prefHeight="26.0" prefWidth="60.0"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Label layoutX="300.0" layoutY="8.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #555555;"
                       text="ESTADO ACTUAL" />
                <TextField fx:id="txtEstadoIncidencia" disable="true" layoutX="396.0" layoutY="4.0"
                           prefHeight="26.0" prefWidth="140.0"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #CC3300; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold;" />
            </children>
        </Pane>

        <!-- CUERPO -->
        <AnchorPane layoutY="92.0"
                    AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="92.0"
                    style="-fx-background-color: #F8FCFF;">
            <children>

                <!-- TIPO DE DEFECTO — solo lectura, cargado desde tbl.Incidencias_Servicio -->
                <Label layoutX="20.0" layoutY="18.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                       text="TIPO DE DEFECTO" />
                <TextField fx:id="txtTipoDefecto" disable="true"
                           layoutX="185.0" layoutY="12.0" prefHeight="28.0" prefWidth="230.0"
                           style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #CC3300 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #CC3300; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;" />

                <!-- SUBSERVICIO AFECTADO — solo lectura -->
                <Label layoutX="20.0" layoutY="54.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                       text="SUBSERVICIO" />
                <TextField fx:id="txtSubservicioAfectado" disable="true"
                           layoutX="185.0" layoutY="48.0" prefHeight="28.0" prefWidth="230.0"
                           style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Line endX="600.0" endY="0.0" layoutX="20.0" layoutY="86.0"
                      style="-fx-stroke: #CC6600; -fx-opacity: 0.4;" />

                <!-- DESCRIPCIÓN ORIGINAL — solo lectura, campo descripcion de la incidencia -->
                <Label layoutX="20.0" layoutY="96.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555555;"
                       text="DESCRIPCIÓN DEL DEFECTO" />
                <TextArea fx:id="txtDescripcionOriginal" disable="true"
                          layoutX="20.0" layoutY="114.0" prefHeight="80.0" prefWidth="600.0"
                          wrapText="true"
                          style="-fx-background-color: #F5F5F5; -fx-border-color: #D9D9D9; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-text-fill: #444444;" />

                <Line endX="600.0" endY="0.0" layoutX="20.0" layoutY="204.0"
                      style="-fx-stroke: #CC6600; -fx-opacity: 0.4;" />

                <!-- OBSERVACIÓN DE RESOLUCIÓN — se concatena al campo descripcion -->
                <Label layoutX="20.0" layoutY="214.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                       text="RESOLUCIÓN *" />
                <Label layoutX="20.0" layoutY="232.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #888888;"
                       text="Describe qué se hizo para corregir el defecto." />
                <TextArea fx:id="txtObservacionResolucion"
                          layoutX="20.0" layoutY="250.0" prefHeight="90.0" prefWidth="600.0"
                          wrapText="true" promptText="Describe la corrección realizada..."
                          style="-fx-background-color: #FFFFFF; -fx-border-color: #FFAA33; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <Line endX="600.0" endY="0.0" layoutX="20.0" layoutY="350.0"
                      style="-fx-stroke: #CC6600; -fx-opacity: 0.4;" />

                <!-- SUPERVISOR — sesión activa -->
                <Label layoutX="20.0" layoutY="362.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                       text="SUPERVISOR" />
                <TextField fx:id="txtSupervisor" disable="true"
                           layoutX="185.0" layoutY="356.0" prefHeight="28.0" prefWidth="240.0"
                           style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />
                <!-- ID oculto fk_supervisor -->
                <TextField fx:id="txtIdSupervisor" disable="true"
                           layoutX="430.0" layoutY="356.0" prefHeight="28.0" prefWidth="60.0"
                           style="-fx-background-color: #F0F5FB; -fx-border-color: transparent; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                <!-- AVISO -->
                <Pane layoutX="20.0" layoutY="396.0" prefHeight="30.0" prefWidth="600.0"
                      style="-fx-background-color: #FFF8E8; -fx-border-color: #FFAA33; -fx-border-width: 1; -fx-border-radius: 2; -fx-background-radius: 2;">
                    <children>
                        <Label layoutX="12.0" layoutY="8.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #CC6600;"
                               text="Si no quedan incidencias abiertas, el servicio volverá a estado TERMINADO." />
                    </children>
                </Pane>

                <!-- BOTONES -->
                <HBox alignment="CENTER" layoutX="20.0" layoutY="438.0"
                      prefHeight="42.0" prefWidth="600.0" spacing="14.0">
                    <children>
                        <!-- sp_ResolverIncidencia -->
                        <Button mnemonicParsing="false" onAction="#fnResolverIncidencia"
                                prefHeight="34.0" prefWidth="160.0"
                                style="-fx-background-color: #CC6600; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #AA5500; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                text="MARCAR RESUELTA">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#fnCancelar"
                                prefHeight="34.0" prefWidth="110.0"
                                style="-fx-background-color: #888888; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 2;"
                                text="CANCELAR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </HBox>

            </children>
        </AnchorPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" prefWidth="640.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #CC6600, #FFAA33);"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
