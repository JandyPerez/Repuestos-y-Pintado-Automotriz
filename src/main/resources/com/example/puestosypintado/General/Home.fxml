                        <Button layoutX="10.0" layoutY="480.0" maxWidth="Infinity" onAction="#irPintura" prefHeight="36.0" style="-fx-background-color: #FFFFFF; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 12;" text="Registrar Incidencia">
