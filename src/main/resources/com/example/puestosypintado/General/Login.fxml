<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="490.0" prefWidth="440.0" style="-fx-background-color: #EBF2FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.LoginController">

    <children>

        <!-- FRANJA SUPERIOR con gradiente -->
        <Pane prefHeight="80.0" prefWidth="440.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Nombre sistema -->
                <Label layoutX="0.0" layoutY="10.0" prefWidth="440.0" style="-fx-font-family: Impact; -fx-font-size: 27px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-alignment: CENTER;" text="REPUESTOS Y PINTADO" />
                <!-- Subtítulo -->
                <Label layoutY="42.0" prefWidth="440.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.80); -fx-alignment: CENTER; -fx-letter-spacing: 1;" text="Sistema de Gestion de Taller  —  Acceso Autorizado" />
            </children>
        </Pane>

        <!-- BADGE RP — sobresale del header hacia la tarjeta -->
        <Pane layoutX="175.0" layoutY="58.0" prefHeight="52.0" prefWidth="90.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6;">
            <children>
                <Label layoutX="0.0" layoutY="4.0" prefWidth="90.0" style="-fx-font-family: Impact; -fx-font-size: 22px; -fx-text-fill: #0066CC; -fx-alignment: CENTER; -fx-font-weight: bold;" text="R&amp;P" />
                <Label layoutX="0.0" layoutY="30.0" prefWidth="90.0" style="-fx-font-family: Courier New; -fx-font-size: 8px; -fx-text-fill: #00AA99; -fx-alignment: CENTER; -fx-font-weight: bold;" text="TALLER" />
            </children>
        </Pane>

        <!-- TARJETA CENTRAL -->
        <VBox layoutX="45.0" layoutY="118.0" prefWidth="350.0" spacing="0.0" style="-fx-background-color: #FFFFFF;                      -fx-border-color: #C5DCF5;                      -fx-border-width: 1;                      -fx-border-radius: 5;                      -fx-background-radius: 5;                      -fx-effect: dropshadow(gaussian, rgba(0,102,204,0.12), 12, 0, 0, 3);">
            <children>

                <!-- Encabezado de la tarjeta -->
                <Label prefWidth="350.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold;                               -fx-text-fill: #0066CC; -fx-background-color: #EEF5FF;                               -fx-border-color: #C5DCF5; -fx-border-width: 0 0 1 0;                               -fx-padding: 9 16 9 16; -fx-border-radius: 5 5 0 0;                               -fx-background-radius: 5 5 0 0;" text="INICIAR SESION" />

                <!-- Formulario -->
                <VBox spacing="16.0" style="-fx-padding: 22 28 18 28;">
                    <children>

                        <!-- Campo Usuario -->
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-family: Courier New; -fx-font-size: 10px;                                               -fx-font-weight: bold; -fx-text-fill: #555555;" text="USUARIO" />
                                <TextField fx:id="txtUsuario" onAction="#fnLogin" promptText="Nombre de usuario" style="-fx-background-color: #F6FAFF;                                                   -fx-border-color: #B3D9FF;                                                   -fx-border-width: 1;                                                   -fx-border-radius: 3;                                                   -fx-background-radius: 3;                                                   -fx-font-family: Courier New;                                                   -fx-font-size: 12px;                                                   -fx-padding: 7 10 7 10;" />
                            </children>
                        </VBox>

                        <!-- Campo Contraseña -->
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-family: Courier New; -fx-font-size: 10px;                                               -fx-font-weight: bold; -fx-text-fill: #555555;" text="CONTRASENA" />
                                <PasswordField fx:id="txtPassword" onAction="#fnLogin" promptText="Contrasena" style="-fx-background-color: #F6FAFF;                                                       -fx-border-color: #B3D9FF;                                                       -fx-border-width: 1;                                                       -fx-border-radius: 3;                                                       -fx-background-radius: 3;                                                       -fx-font-family: Courier New;                                                       -fx-font-size: 12px;                                                       -fx-padding: 7 10 7 10;" />
                            </children>
                        </VBox>

                        <!-- Fila de avisos: error | intentos -->
                        <HBox spacing="8.0">
                            <children>
                                <!-- Mensaje de error -->
                                <Label fx:id="lblError" maxWidth="Infinity" style="-fx-font-family: Courier New; -fx-font-size: 10px;                                               -fx-text-fill: #CC0000; -fx-font-weight: bold;                                               -fx-wrap-text: true;" text="" visible="false" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <!-- Intentos restantes (se hace visible tras 1er fallo) -->
                        <Label fx:id="lblIntentos" prefWidth="294.0" style="-fx-font-family: Courier New; -fx-font-size: 10px;                                       -fx-text-fill: #E65C00; -fx-alignment: CENTER-RIGHT;                                       -fx-font-weight: bold;" text="" visible="false" />

                        <!-- Botón ENTRAR -->
                        <Button fx:id="btnEntrar" maxWidth="Infinity" onAction="#fnLogin" prefHeight="38.0" style="-fx-background-color: #0066CC;                                        -fx-text-fill: #FFFFFF;                                        -fx-font-family: Courier New;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-border-color: #0052A3;                                        -fx-border-width: 1;                                        -fx-background-radius: 3;                                        -fx-border-radius: 3;" text="ENTRAR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                    </children>
                </VBox>

            </children>
        </VBox>

        <!-- Info de sesión / bloqueo (contador regresivo) -->
        <Label fx:id="lblBloqueo" layoutX="0.0" layoutY="424.0" prefWidth="440.0" style="-fx-font-family: Courier New; -fx-font-size: 10px;                       -fx-text-fill: #CC4400; -fx-alignment: CENTER; -fx-font-weight: bold;" text="" visible="false" />

        <!-- FRANJA INFERIOR -->
        <Pane prefHeight="6.0" prefWidth="440.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

        <!-- Footer: versión y aviso -->
        <Label layoutX="0.0" layoutY="460.0" prefWidth="440.0" style="-fx-font-family: Courier New; -fx-font-size: 8px;                       -fx-text-fill: #AAAAAA; -fx-alignment: CENTER;" text="v1.0  |  Solo usuarios Activos pueden acceder  |  Repuestos y Pintado" />

    </children>
</AnchorPane>
