<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="690.0" prefWidth="920.0" style="-fx-background-color: #F0F5FB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.puestosypintado.controladores.PagoController">
    <children>

        <!-- HEADER -->
        <Pane prefHeight="48.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0"
                       style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;"
                       text="CONTROL DE PAGOS" />
                <Label layoutX="480.0" layoutY="17.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"
                       text="FERRETERIA — FACTURACION Y COBROS" />
            </children>
        </Pane>

        <!-- HOME -->
        <Button onAction="#irHome" text="HOME" prefHeight="26.0" prefWidth="80.0"
                style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.50); -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3;"
                AnchorPane.topAnchor="11.0" AnchorPane.rightAnchor="12.0">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <!-- MAIN SPLIT PANE -->
        <SplitPane dividerPositions="0.42" layoutY="48.0" prefHeight="636.0" prefWidth="920.0"
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;"
                   AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- LEFT — TABLE -->
                <AnchorPane minHeight="0.0" minWidth="0.0"
                            style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="HISTORIAL DE PAGOS" />
                        <TableView fx:id="tvPagos" layoutY="32.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;"
                                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colIdPago"      prefWidth="50.0"  text="ID" />
                                <TableColumn fx:id="colClientePago" prefWidth="140.0" text="CLIENTE" />
                                <TableColumn fx:id="colMontoPago"   prefWidth="90.0"  text="MONTO" />
                                <TableColumn fx:id="colFechaPago"   prefWidth="100.0" text="FECHA" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- RIGHT — FORM -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ID PAGO -->
                        <Label layoutX="20.0" layoutY="18.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="ID PAGO" />
                        <TextField fx:id="txtIdPago" layoutX="110.0" layoutY="12.0"
                                   prefHeight="28.0" prefWidth="80.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px;" />
                        <Button layoutX="198.0" layoutY="12.0" onAction="#fnBuscarPago"
                                prefHeight="28.0" prefWidth="34.0"
                                style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;"
                                text="🔍">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <Line endX="445.0" endY="0.0" layoutY="50.0" startX="20.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- CLIENTE -->
                        <Label layoutX="20.0" layoutY="63.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="CLIENTE *" />
                        <ComboBox fx:id="cmbClientePago" layoutX="110.0" layoutY="59.0"
                                  prefHeight="28.0" prefWidth="310.0" promptText="Seleccione cliente..."
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />

                        <!-- MONTO -->
                        <Label layoutX="20.0" layoutY="101.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="MONTO *" />
                        <TextField fx:id="txtMontoPago" layoutX="110.0" layoutY="97.0"
                                   prefHeight="28.0" prefWidth="130.0" promptText="0.00"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 12px; -fx-prompt-text-fill: #9999CC;" />

                        <!-- METODO DE PAGO -->
                        <Label layoutX="20.0" layoutY="139.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="METODO *" />
                        <ComboBox fx:id="cmbMetodoPago" layoutX="110.0" layoutY="135.0"
                                  prefHeight="28.0" prefWidth="200.0"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;" />

                        <!-- FECHA -->
                        <Label layoutX="20.0" layoutY="177.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="FECHA" />
                        <TextField fx:id="txtFechaPago" disable="true" layoutX="110.0" layoutY="173.0"
                                   prefHeight="28.0" prefWidth="200.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #888888; -fx-font-family: Courier New; -fx-font-size: 12px;" />

                        <!-- SALDO PENDIENTE (solo lectura) -->
                        <Label layoutX="20.0" layoutY="215.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="SALDO PEND." />
                        <TextField fx:id="txtSaldoPago" disable="true" layoutX="110.0" layoutY="211.0"
                                   prefHeight="28.0" prefWidth="200.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #FF6B6B transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #CC0000; -fx-font-family: Courier New; -fx-font-size: 13px; -fx-font-weight: bold;" />

                        <Line endX="445.0" endY="0.0" layoutY="254.0" startX="20.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- BOTONES -->
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="264.0"
                              prefHeight="42.0" prefWidth="475.0" spacing="10.0"
                              AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnRegistrarPago"
                                        prefHeight="34.0" prefWidth="130.0"
                                        style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="REGISTRAR PAGO">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnBorrarPago"
                                        prefHeight="34.0" prefWidth="90.0"
                                        style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #E63939; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="BORRAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiarPago"
                                        prefHeight="34.0" prefWidth="90.0"
                                        style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </AnchorPane>
            </items>
        </SplitPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
    </children>
</AnchorPane>
