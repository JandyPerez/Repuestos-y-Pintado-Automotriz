<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="690.0" prefWidth="920.0" style="-fx-background-color: #F0F5FB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.puestosypintado.controladores.NuevaOrdenController">
    <children>

        <!-- HEADER -->
        <Pane prefHeight="48.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0"
                       style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;"
                       text="SERVICIO DE PINTURA" />
                <Label layoutX="480.0" layoutY="17.0"
                       style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"
                       text="TALLER — NUEVA ORDEN DE TRABAJO" />
            </children>
        </Pane>

        <!-- HOME -->
        <Button onAction="#irHome" text="HOME" prefHeight="26.0" prefWidth="80.0"
                style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.50); -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3;"
                AnchorPane.topAnchor="11.0" AnchorPane.rightAnchor="12.0">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <!-- SPLIT PANE -->
        <SplitPane dividerPositions="0.36" layoutY="48.0" prefHeight="636.0" prefWidth="920.0"
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;"
                   AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- IZQUIERDA — BUSCADOR DE CLIENTES -->
                <AnchorPane minHeight="0.0" minWidth="0.0"
                            style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="BUSCAR CLIENTE" />

                        <TextField fx:id="txtBuscarCliente" layoutX="10.0" layoutY="32.0"
                                   prefHeight="28.0" prefWidth="220.0" promptText="Nombre o cedula..."
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />
                        <!-- FIX: "?" → "🔍" -->
                        <Button fx:id="btnBuscarCliente" layoutX="238.0" layoutY="32.0"
                                onAction="#fnBuscarCliente" prefHeight="28.0" prefWidth="34.0"
                                style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;"
                                text="🔍">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <TableView fx:id="tvClientes" layoutY="66.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;"
                                   AnchorPane.bottomAnchor="220.0" AnchorPane.leftAnchor="0.0"
                                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="66.0">
                            <columns>
                                <TableColumn fx:id="colClienteNombre" prefWidth="170.0" text="NOMBRE" />
                                <TableColumn fx:id="colClienteCedula" prefWidth="100.0" text="CEDULA" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <Label style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="VEHICULOS DEL CLIENTE"
                               AnchorPane.bottomAnchor="196.0" AnchorPane.leftAnchor="10.0" />

                        <TableView fx:id="tvVehiculos"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;"
                                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="442.0">
                            <columns>
                                <TableColumn fx:id="colVehiculoPlaca"  prefWidth="90.0"  text="PLACA" />
                                <TableColumn fx:id="colVehiculoModelo" prefWidth="140.0" text="MARCA / MODELO" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- DERECHA — FORMULARIO DE ORDEN -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <Label layoutX="15.0" layoutY="18.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="CLIENTE" />
                        <TextField fx:id="txtClienteSeleccionado" disable="true"
                                   layoutX="130.0" layoutY="12.0" prefHeight="28.0" prefWidth="200.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Label layoutX="345.0" layoutY="18.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="ID CLIENTE" />
                        <TextField fx:id="txtIdCliente" disable="true"
                                   layoutX="430.0" layoutY="12.0" prefHeight="28.0" prefWidth="100.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Label layoutX="15.0" layoutY="55.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="VEHICULO" />
                        <TextField fx:id="txtVehiculoSeleccionado" disable="true"
                                   layoutX="130.0" layoutY="49.0" prefHeight="28.0" prefWidth="200.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Label layoutX="345.0" layoutY="55.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;"
                               text="ID VEHICULO" />
                        <TextField fx:id="txtIdVehiculo" disable="true"
                                   layoutX="430.0" layoutY="49.0" prefHeight="28.0" prefWidth="100.0"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Line endX="540.0" endY="0.0" layoutY="88.0" startX="15.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <Label layoutX="15.0" layoutY="100.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="DESCRIPCION *" />
                        <TextArea fx:id="txtDescripcionTrabajo" layoutX="15.0" layoutY="118.0"
                                  prefHeight="80.0" prefWidth="535.0" wrapText="true"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Label layoutX="15.0" layoutY="210.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="OBSERVACIONES" />
                        <TextArea fx:id="txtObservaciones" layoutX="15.0" layoutY="228.0"
                                  prefHeight="60.0" prefWidth="535.0" wrapText="true"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Line endX="540.0" endY="0.0" layoutY="300.0" startX="15.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <Label layoutX="15.0" layoutY="316.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="MONTO COTIZADO" />
                        <TextField fx:id="txtMontoCotizado" layoutX="160.0" layoutY="310.0"
                                   prefHeight="28.0" prefWidth="120.0" promptText="0.00"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: Courier New; -fx-font-size: 12px;" />

                        <Label layoutX="300.0" layoutY="316.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text=" ANTICIPO" />
                        <TextField fx:id="txtPorcentajeAnticipo" layoutX="400.0" layoutY="310.0"
                                   prefHeight="28.0" prefWidth="60.0" text="40"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: Courier New; -fx-font-size: 12px;" />
                        <Label layoutX="465.0" layoutY="316.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-text-fill: #666666;"
                               text="%" />

                        <Label layoutX="15.0" layoutY="356.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="FECHA PROMETIDA" />
                        <DatePicker fx:id="dpFechaPrometida" layoutX="180.0" layoutY="350.0"
                                    prefHeight="28.0" prefWidth="160.0"
                                    style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Label layoutX="15.0" layoutY="396.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="LIMITE ANTICIPO" />
                        <DatePicker fx:id="dpFechaLimitePago" layoutX="180.0" layoutY="390.0"
                                    prefHeight="28.0" prefWidth="160.0"
                                    style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: Courier New; -fx-font-size: 11px;" />
                        <Label layoutX="346.0" layoutY="396.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: #888888;"
                               text="(Auto: hoy + 7 dias)" />

                        <Label layoutX="15.0" layoutY="436.0"
                               style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;"
                               text="ESTADO" />
                        <TextField fx:id="txtEstado" disable="true"
                                   layoutX="180.0" layoutY="430.0" prefHeight="28.0" prefWidth="120.0"
                                   text="cotizado"
                                   style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 11px;" />

                        <Line endX="540.0" endY="0.0" layoutY="472.0" startX="15.0" startY="0.0"
                              style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <HBox alignment="CENTER" layoutX="10.0" layoutY="486.0"
                              prefHeight="42.0" prefWidth="555.0" spacing="12.0"
                              AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarOrden"
                                        prefHeight="34.0" prefWidth="110.0"
                                        style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="GUARDAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiar"
                                        prefHeight="34.0" prefWidth="110.0"
                                        style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnIrSubservicios"
                                        prefHeight="34.0" prefWidth="160.0"
                                        style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;"
                                        text="VER SUBSERVICIOS">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </AnchorPane>
            </items>
        </SplitPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" prefWidth="920.0"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
    </children>
</AnchorPane>
