<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1200.0" prefWidth="907.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.NuevaOrdenController">
    <children>

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <Pane prefHeight="48.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="SERVICIO DE PINTURA" />
                <Label layoutX="300.0" layoutY="17.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="TALLER — NUEVA ORDEN DE TRABAJO" />
            </children>
        </Pane>

        <!-- Botón HOME (flotante sobre el header) -->
        <Button onAction="#irHome" prefHeight="26.0" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.50); -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3;" text="HOME" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="11.0">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <!-- ═══════════════════ SPLIT PANE ═══════════════════ -->
        <SplitPane dividerPositions="0.42" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- ─── IZQUIERDA: buscador de clientes ─── -->
                <AnchorPane minHeight="0.0" minWidth="200.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <VBox spacing="6.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="12.0" /></padding>

                            <!-- Sección clientes -->
                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="BUSCAR CLIENTE" />

                            <HBox spacing="6.0">
                                <TextField fx:id="txtBuscarCliente" prefHeight="28.0" promptText="Nombre o cédula..." style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnBuscarCliente" onAction="#fnBuscarCliente" prefHeight="28.0" prefWidth="34.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;" text="🔍">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </HBox>


                            <!-- Tablas en proporción 2:1 (clientes = doble de vehículos) -->
                            <SplitPane dividerPositions="0.6667" orientation="VERTICAL" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                                <items>

                                    <!-- Tabla CLIENTES (2/3 del espacio) -->
                                    <AnchorPane minHeight="0.0" style="-fx-background-color: transparent;">
                                        <children>
                                            <VBox spacing="4.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="CLIENTES" />
                                                <TableView fx:id="tvClientes" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colClienteNombre" prefWidth="160.0" text="NOMBRE" />
                                                        <TableColumn fx:id="colClienteCedula" prefWidth="100.0" text="CEDULA" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </VBox>
                                        </children>
                                    </AnchorPane>

                                    <!-- Tabla VEHÍCULOS (1/3 del espacio) -->
                                    <AnchorPane minHeight="0.0" style="-fx-background-color: transparent;">
                                        <children>
                                            <VBox spacing="4.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="VEHÍCULOS DEL CLIENTE" />
                                                <TableView fx:id="tvVehiculos" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colVehiculoPlaca" prefWidth="90.0" text="PLACA" />
                                                        <TableColumn fx:id="colVehiculoModelo" prefWidth="140.0" text="MARCA / MODELO" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </VBox>
                                        </children>
                                    </AnchorPane>

                                </items>
                            </SplitPane>

                        </VBox>
                    </children>
                </AnchorPane>

                <!-- ─── DERECHA: formulario de orden ─── -->
                <AnchorPane minHeight="0.0" minWidth="260.0" style="-fx-background-color: #F8FCFF;">
                    <children>
                        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                            <!-- Datos fijos: cliente y vehículo -->
                            <GridPane hgap="10.0" vgap="8.0">
                                <padding><Insets bottom="10.0" left="16.0" right="16.0" top="14.0" /></padding>

                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="CLIENTE" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="txtClienteSeleccionado" disable="true" maxWidth="Infinity" prefHeight="28.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="0" />
                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="ID" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextField fx:id="txtIdCliente" disable="true" prefHeight="28.0" prefWidth="80.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="VEHÍCULO" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="txtVehiculoSeleccionado" disable="true" maxWidth="Infinity" prefHeight="28.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" />
                                <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="ID VEH" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextField fx:id="txtIdVehiculo" disable="true" prefHeight="28.0" prefWidth="80.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <columnConstraints>
                           <ColumnConstraints />
                           <ColumnConstraints />
                           <ColumnConstraints />
                           <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                        </rowConstraints>
                            </GridPane>

                            <Separator style="-fx-background-color: rgba(0,102,204,0.25);" />
               
                            <!-- ScrollPane para el resto del formulario -->
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                                <content>
                                    <VBox spacing="12.0">
                                        <padding>
                                 <Insets bottom="16.0" left="16.0" right="16.0" top="12.0" />
                              </padding>
               
                                        <!-- Descripción -->
                                        <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="DESCRIPCIÓN *" />
                                        <TextArea fx:id="txtDescripcionTrabajo" maxWidth="Infinity" prefHeight="80.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" wrapText="true" />
               
                                        <!-- Observaciones -->
                                        <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="OBSERVACIONES" />
                                        <TextArea fx:id="txtObservaciones" maxWidth="Infinity" prefHeight="60.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" wrapText="true" />
               
                                        <Separator style="-fx-background-color: rgba(0,102,204,0.2);" />
                              <TableView fx:id="tvOrdenSubservicios" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;">
                                 <columns>
                                    <TableColumn fx:id="colDetalleNombre" prefWidth="160.0" text="SUBSERVICIO" />
                                    <TableColumn fx:id="colDetallePrecio" prefWidth="100.0" text="PIEZA" />
                                    <TableColumn fx:id="colDetalleEstado" prefWidth="110.0" text="COSTO BASE" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
                              <Separator style="-fx-background-color: rgba(0,102,204,0.2);" />
               
                                        <!-- Monto y anticipo -->
                                        <GridPane hgap="12.0" vgap="8.0">
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="MONTO COTIZADO" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                            <TextField fx:id="txtMontoCotizado" disable="true" editable="false" prefHeight="28.0" prefWidth="130.0" promptText="0.00" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
               
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ANTICIPO %" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                            <TextField fx:id="txtPorcentajeAnticipo" prefHeight="28.0" prefWidth="70.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" text="40" GridPane.columnIndex="3" GridPane.rowIndex="0" />
               
                                            <!-- Fechas -->
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="FECHA PROMETIDA" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                            <DatePicker fx:id="dpFechaPrometida" prefHeight="28.0" prefWidth="160.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="LÍMITE ANTICIPO" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                            <DatePicker fx:id="dpFechaLimitePago" prefHeight="28.0" prefWidth="160.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: #888888;" text="(Auto: hoy + 7 días)" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="2" />
               
                                            <!-- Estado -->
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ESTADO" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                            <TextField fx:id="txtEstado" disable="true" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 11px;" text="Cotizado" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 <columnConstraints>
                                    <ColumnConstraints />
                                    <ColumnConstraints />
                                    <ColumnConstraints />
                                    <ColumnConstraints />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                 </rowConstraints>
                                        </GridPane>
               
                                        <Separator style="-fx-background-color: rgba(0,102,204,0.2);" />
               
                                        <!-- Botones -->
                                        <HBox alignment="CENTER" spacing="12.0">
                                            <Button mnemonicParsing="false" onAction="#fnGuardarOrden" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 4; -fx-border-radius: 4;" text="GUARDAR">
                                                <cursor>
                                       <Cursor fx:constant="HAND" />
                                    </cursor>
                                            </Button>
                                            <Button mnemonicParsing="false" onAction="#fnLimpiar" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 4; -fx-border-radius: 4;" text="LIMPIAR">
                                                <cursor>
                                       <Cursor fx:constant="HAND" />
                                    </cursor>
                                            </Button>
                                            <Button mnemonicParsing="false" onAction="#fnIrSubservicios" prefHeight="36.0" prefWidth="160.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 4; -fx-border-radius: 4;" text="VER SUBSERVICIOS">
                                                <cursor>
                                       <Cursor fx:constant="HAND" />
                                    </cursor>
                                            </Button>
                                        </HBox>
               
                                    </VBox>
                                </content>
                            </ScrollPane>

                        </VBox>
                    </children>
                </AnchorPane>

            </items>
        </SplitPane>

        <!-- BOTTOM STRIP -->
        <Pane prefHeight="6.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
